<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080E1B">

    <!-- ─── TOP BAR ─── -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:background="#0D1117">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Retour" />

        <TextView
            android:id="@+id/lblOfficeTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Léa Office"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="4dp" />

        <EditText
            android:id="@+id/edDocTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Titre du document..."
            android:textColor="#FFFFFF"
            android:textColorHint="#4A5568"
            android:textSize="15sp"
            android:background="@android:color/transparent"
            android:paddingStart="4dp"
            android:singleLine="true"
            android:imeOptions="actionDone"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Sauv."
            android:textColor="#00F2FF"
            android:textSize="11sp"
            android:backgroundTint="#001C22"
            android:visibility="gone"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Suppr."
            android:textColor="#FF5555"
            android:textSize="11sp"
            android:backgroundTint="#220000"
            android:visibility="gone" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A2233"/>

    <!-- ─── CONTENT FRAME ─── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ════ ÉCRAN 1 : LISTE DES DOCUMENTS ════ -->
        <LinearLayout
            android:id="@+id/screenList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:text="📄"
                    android:textSize="56sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
                <TextView
                    android:text="Aucun document"
                    android:textColor="#4A5568"
                    android:textSize="15sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="12dp" />
                <TextView
                    android:text="Créez votre premier document ci-dessous"
                    android:textColor="#2A3A50"
                    android:textSize="12sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingTop="6dp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/docScrollView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">
                <LinearLayout
                    android:id="@+id/docListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp" />
            </ScrollView>

            <Button
                android:id="@+id/btnNewDoc"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="＋  Nouveau Document"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="14sp"
                android:backgroundTint="#00F2FF"
                android:layout_margin="16dp" />
        </LinearLayout>

        <!-- ════ ÉCRAN 2 : ÉDITEUR ════ -->
        <LinearLayout
            android:id="@+id/screenEditor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Barre de formatage -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="#0D1117"
                android:scrollbars="none"
                android:fillViewport="false">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp">

                    <Button android:id="@+id/fmtBold"   android:layout_width="38dp" android:layout_height="34dp" android:text="B" android:textStyle="bold"  android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="13sp" android:padding="0dp" />
                    <Button android:id="@+id/fmtItalic" android:layout_width="38dp" android:layout_height="34dp" android:text="I" android:textStyle="italic" android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="13sp" android:padding="0dp" android:layout_marginStart="3dp" />
                    <Button android:id="@+id/fmtUnder"  android:layout_width="38dp" android:layout_height="34dp" android:text="U"                           android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="13sp" android:padding="0dp" android:layout_marginStart="3dp" />

                    <View android:layout_width="1dp" android:layout_height="18dp" android:background="#2A3344" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                    <Button android:id="@+id/fmtH1"    android:layout_width="40dp" android:layout_height="34dp" android:text="H1" android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="12sp" android:padding="0dp" />
                    <Button android:id="@+id/fmtH2"    android:layout_width="40dp" android:layout_height="34dp" android:text="H2" android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="12sp" android:padding="0dp" android:layout_marginStart="3dp" />
                    <Button android:id="@+id/fmtPara"  android:layout_width="40dp" android:layout_height="34dp" android:text="¶"  android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="14sp" android:padding="0dp" android:layout_marginStart="3dp" />

                    <View android:layout_width="1dp" android:layout_height="18dp" android:background="#2A3344" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                    <Button android:id="@+id/fmtUList" android:layout_width="42dp" android:layout_height="34dp" android:text="• —" android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="11sp" android:padding="0dp" />
                    <Button android:id="@+id/fmtOList" android:layout_width="38dp" android:layout_height="34dp" android:text="1."  android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="12sp" android:padding="0dp" android:layout_marginStart="3dp" />

                    <View android:layout_width="1dp" android:layout_height="18dp" android:background="#2A3344" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                    <Button android:id="@+id/fmtAlignL" android:layout_width="38dp" android:layout_height="34dp" android:text="⬅"  android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="13sp" android:padding="0dp" />
                    <Button android:id="@+id/fmtAlignC" android:layout_width="38dp" android:layout_height="34dp" android:text="↔"  android:textColor="#CCDDEE" android:backgroundTint="#1A2233" android:textSize="13sp" android:padding="0dp" android:layout_marginStart="3dp" />

                    <View android:layout_width="1dp" android:layout_height="18dp" android:background="#2A3344" android:layout_marginStart="6dp" android:layout_marginEnd="6dp" />

                    <Button android:id="@+id/fmtClear"  android:layout_width="42dp" android:layout_height="34dp" android:text="Tx" android:textColor="#FF6666"  android:backgroundTint="#1A2233" android:textSize="12sp" android:padding="0dp" />
                </LinearLayout>
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A2233"/>

            <!-- Zone d'édition WebView -->
            <WebView
                android:id="@+id/webEditor"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ─── PANNEAU LÉA ─── -->
            <LinearLayout
                android:id="@+id/leaPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#0D1117">

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#00F2FF44"/>

                <!-- Barre compacte (toujours visible) -->
                <LinearLayout
                    android:id="@+id/leaBar"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:text="✨ Léa"
                        android:textColor="#00F2FF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/leaStatusText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Appuyez pour demander à Léa"
                        android:textColor="#4A5568"
                        android:textSize="11sp"
                        android:paddingStart="10dp" />

                    <TextView
                        android:id="@+id/leaChevron"
                        android:text="▲"
                        android:textColor="#4A5568"
                        android:textSize="10sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Panneau étendu (masqué par défaut) -->
                <LinearLayout
                    android:id="@+id/leaExpanded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="12dp"
                    android:visibility="gone">

                    <!-- Actions rapides -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="10dp">
                        <Button android:id="@+id/qaCorriger"   android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"                                android:text="Corriger"   android:textSize="9sp" android:textColor="#00F2FF" android:backgroundTint="#001C22" android:padding="0dp" />
                        <Button android:id="@+id/qaAmeliorer"  android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginStart="5dp" android:text="Améliorer"  android:textSize="9sp" android:textColor="#00F2FF" android:backgroundTint="#001C22" android:padding="0dp" />
                        <Button android:id="@+id/qaReformuler" android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginStart="5dp" android:text="Reformuler" android:textSize="9sp" android:textColor="#00F2FF" android:backgroundTint="#001C22" android:padding="0dp" />
                        <Button android:id="@+id/qaContinuer"  android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1" android:layout_marginStart="5dp" android:text="Continuer"  android:textSize="9sp" android:textColor="#00F2FF" android:backgroundTint="#001C22" android:padding="0dp" />
                    </LinearLayout>

                    <!-- Saisie personnalisée -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/leaInput"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Demander à Léa..."
                            android:textColor="#FFFFFF"
                            android:textColorHint="#4A5568"
                            android:textSize="13sp"
                            android:backgroundTint="#2A3344"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:maxLines="3"
                            android:inputType="textMultiLine|textCapSentences" />

                        <Button
                            android:id="@+id/btnLeaSend"
                            android:layout_width="52dp"
                            android:layout_height="42dp"
                            android:text="➤"
                            android:textColor="#00F2FF"
                            android:backgroundTint="#001C22"
                            android:textSize="16sp"
                            android:padding="0dp"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <!-- Chargement -->
                    <ProgressBar
                        android:id="@+id/leaLoading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:paddingTop="10dp"
                        android:visibility="gone" />

                    <!-- Résultat -->
                    <LinearLayout
                        android:id="@+id/leaResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:paddingTop="10dp">

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="130dp">
                            <TextView
                                android:id="@+id/leaResultText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#E0E8F0"
                                android:textSize="13sp"
                                android:lineSpacingExtra="4dp"
                                android:background="#060C18"
                                android:padding="10dp" />
                        </ScrollView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingTop="8dp">
                            <Button android:id="@+id/btnInsert"  android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"                                android:text="Insérer"    android:textColor="#000000" android:backgroundTint="#00F2FF" android:textSize="11sp" android:padding="0dp" />
                            <Button android:id="@+id/btnReplace" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="Remplacer"  android:textColor="#FFFFFF" android:backgroundTint="#7B68EE" android:textSize="11sp" android:padding="0dp" />
                            <Button android:id="@+id/btnRetry"   android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="Réessayer"  android:textColor="#AABBCC" android:backgroundTint="#1A2233" android:textSize="11sp" android:padding="0dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</LinearLayout>
