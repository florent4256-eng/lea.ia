<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="false">

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  BARRE DU HAUT                                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#000000"
            android:contentDescription="Retour"
            android:padding="12dp" />

        <TextView
            android:id="@+id/topBarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@id/btnBack"
            android:text="Léa"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:letterSpacing="0.01" />

    </RelativeLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E5E7EB" />

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  ZONE CENTRALE                                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:clipChildren="false"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- ─── HALO FUMÉE + icônes flottantes ─── -->
            <FrameLayout
                android:id="@+id/haloContainer"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center_horizontal"
                android:background="@android:color/transparent">

                <com.flolov42.lea_v3.ui.HaloView
                    android:id="@+id/haloView"
                    android:layout_width="300dp"
                    android:layout_height="300dp"
                    android:layout_gravity="center"
                    android:background="@android:color/transparent" />

                <!-- ✓ à jour -->
                <TextView
                    android:id="@+id/iconCheck"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✓"
                    android:textSize="64sp"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#00000066"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="10"
                    android:visibility="gone" />

                <!-- ↓ mise à jour -->
                <TextView
                    android:id="@+id/iconUpdate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="↓"
                    android:textSize="64sp"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#00000066"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="10"
                    android:visibility="gone" />

                <!-- Spinner -->
                <ProgressBar
                    android:id="@+id/iconSpinner"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_gravity="center"
                    android:indeterminateTint="#FFFFFF"
                    android:visibility="visible" />

            </FrameLayout>

            <!-- Titre statut -->
            <TextView
                android:id="@+id/statusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Vérification..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:gravity="center"
                android:letterSpacing="-0.01" />

            <!-- Sous-titre -->
            <TextView
                android:id="@+id/statusSubtext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text=""
                android:textSize="13sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:lineSpacingExtra="2dp" />

            <!-- Version badge -->
            <TextView
                android:id="@+id/currentVersionBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:text=""
                android:gravity="center" />

            <!-- Changelog -->
            <LinearLayout
                android:id="@+id/changelogSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:background="@drawable/changelog_card_light"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NOUVEAUTÉS"
                    android:textSize="10sp"
                    android:textColor="#9CA3AF"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/changelogText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Barre de téléchargement -->
            <LinearLayout
                android:id="@+id/downloadSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical"
                android:visibility="gone">

                <ProgressBar
                    android:id="@+id/downloadProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="100"
                    android:progressTint="#0088ff"
                    android:progressBackgroundTint="#E5E7EB" />

                <TextView
                    android:id="@+id/downloadProgressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:text="0%"
                    android:textSize="12sp"
                    android:textColor="#9CA3AF" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  ZONE BAS                                             -->
    <!-- ══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/noteAutoUpdate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Les mises à jour obligatoires sont installées automatiquement au démarrage."
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:gravity="center"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Rechercher les mises à jour"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.01"
            android:background="@drawable/btn_update_dark"
            android:enabled="false"
            android:stateListAnimator="@null"
            android:elevation="0dp" />

        <TextView
            android:id="@+id/btnLater"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:text="Plus tard"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
