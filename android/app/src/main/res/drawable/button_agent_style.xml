<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/button_agent_purple" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/button_highlight_light" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_agent_bg" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#667B2CBF" />
        </shape>
    </item>
</selector>
