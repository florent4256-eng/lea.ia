<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- État pressé -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2200D9FF" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/button_telephone_green" />
        </shape>
    </item>

    <!-- État normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D00D9FF" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#5900D9FF" />
        </shape>
    </item>

</selector>
