<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- État pressé -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#FF0D2A5E" />
            <corners android:radius="12dp" />
            <stroke android:width="2dp" android:color="@color/lea_cyan" />
        </shape>
    </item>

    <!-- État normal -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/button_terminal_dark_blue" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/button_terminal_border" />
        </shape>
    </item>

</selector>
