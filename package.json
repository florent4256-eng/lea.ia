{
  "name": "lea-v3-souveraine",
  "private": true,
  "version": "4.1.0",
  "description": "Léa V3 — frontend web (React/Vite) et app Android (Capacitor) de l'assistante IA souveraine multi-utilisateurs.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && rm -rf ../lea-server/dist && cp -r dist ../lea-server/",
    "deploy:apk": "npm run deploy && npx cap copy android && cd android && ./gradlew assembleRelease && LEA_V=$(node -e 'process.stdout.write(require(\"../package.json\").version)') && cp app/build/outputs/apk/release/app-release.apk \"../../lea-server/public/apk/lea-v${LEA_V}.apk\" && echo \"✅ APK lea-v${LEA_V}.apk déployé\""
  },
